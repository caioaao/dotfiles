.aider*

# Claude Code runtime data (not configuration)
stow-modules/claude-code/.claude/cache/
stow-modules/claude-code/.claude/history.jsonl
stow-modules/claude-code/.claude/plugins/
stow-modules/claude-code/.claude/projects/

.claude/settings.local.json

# Pi runtime data
/.pi/
stow-modules/pi/.pi/agent/sessions/
stow-modules/pi/.pi/agent/auth.json
stow-modules/pi/.pi/agent/git/
stow-modules/pi/.pi/agent/extensions/*/node_modules/
stow-modules/pi/.pi/agent/node_modules/
stow-modules/pi/.pi/agent/package-lock.json
stow-modules/pi/.pi/agent/trust.json

# white list pi config
!/.pi/prompts/
!/.pi/settings.json

# Machine-specific git config (not tracked)
stow-modules/git/.config/git/config.local
/.local/

# pi packages built by nix; node_modules only appears during local dev
nix-modules/shared/pi-packages/*/node_modules/
