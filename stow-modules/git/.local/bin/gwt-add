#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <branch-name>"
  echo "Creates a new git worktree with the given branch name."
  exit 1
}

BRANCH_NAME="${1:-}"
[[ -z "$BRANCH_NAME" ]] && usage

ROOT_DIR="$(git rev-parse --show-toplevel)"
WORKTREE_DIR="$ROOT_DIR/../$BRANCH_NAME"

if [[ -d "$WORKTREE_DIR" ]]; then
  echo "Error: Directory already exists: $WORKTREE_DIR" >&2
  exit 1
fi

if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
  git worktree add "$WORKTREE_DIR" "$BRANCH_NAME"
else
  git worktree add "$WORKTREE_DIR" -b "$BRANCH_NAME"
fi

echo "Worktree created at $(cd "$WORKTREE_DIR" && pwd)"

# Run post-create hook if present
# Hook path configurable via GWT_POST_CREATE_HOOK
# Can be a file path or an inline command string
if [[ -n "${GWT_POST_CREATE_HOOK:-}" ]]; then
  echo "Running post-create hook..."
  export GWT_WORKTREE_DIR="$WORKTREE_DIR"
  export GWT_BRANCH_NAME="$BRANCH_NAME"
  export GWT_ROOT_DIR="$ROOT_DIR"

  (cd "$WORKTREE_DIR" && bash -c "$GWT_POST_CREATE_HOOK") || {
    echo "Warning: hook failed (exit $?)" >&2
  }
fi
