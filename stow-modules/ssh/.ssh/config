Include ~/.orbstack/ssh/config

# 1Password SSH agent - Linux path
Match host * exec "test -S ~/.1password/agent.sock"
  IdentityAgent ~/.1password/agent.sock

# 1Password SSH agent - macOS path
Match host * exec "test -S '%d/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock'"
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

Host nixos-cloud
  ForwardAgent yes
  ServerAliveInterval 60
  ServerAliveCountMax 3

# Force a specific SSH key for GitHub. Requires ~/.ssh/github.pub to exist.
# This prevents SSH from offering the wrong key when multiple are available
# (e.g. agent forwarding with both personal and work GitHub keys).
# To set up on a new host:
#   ssh-add -L | grep '<desired key comment>' > ~/.ssh/github.pub
Match host github.com exec "test -f ~/.ssh/github.pub || (printf '\\n  ERROR: ~/.ssh/github.pub not found.\\n  Set it up with: ssh-add -L | grep <key-comment> > ~/.ssh/github.pub\\n\\n' >&2 && false)"
  IdentityFile ~/.ssh/github.pub

# Fallback: block GitHub auth if github.pub is not set up
Host github.com
  IdentitiesOnly yes
