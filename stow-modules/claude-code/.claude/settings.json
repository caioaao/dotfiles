{
  "permissions": {
    "allow": [
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(cat:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "${HOME}/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
